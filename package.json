{
  "name": "wuwa-lore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --check .",
    "data:sync": "tsx scripts/sync-fandom-data.ts && npm run data:sync-official",
    "data:sync-official": "tsx scripts/sync-official-versions.ts",
    "data:sync-stories": "tsx scripts/sync-story-appearances.ts && tsx scripts/sync-story-dialogue-stats.ts && tsx scripts/sync-character-display-names.ts",
    "data:sync-portraits": "tsx scripts/sync-character-portraits.ts",
    "data:audit-stories": "tsx scripts/audit-story-appearance-dialogue.ts && tsx scripts/verify-story-dialogue-coverage.ts",
    "data:sync-story-dialogue": "tsx scripts/sync-story-dialogue-stats.ts",
    "data:generate-half-stats": "tsx scripts/generate-version-half-stats.ts",
    "data:generate": "tsx scripts/generate-voice-stats.ts && npm run data:generate-half-stats",
    "data:validate": "tsx scripts/validate-data.ts",
    "data:compare": "tsx scripts/compare-official-vs-fandom.ts",
    "data:check": "npm run data:generate && npm run data:validate && npm run data:compare && npm run data:audit-stories",
    "data:refresh-all": "npm run data:sync-stories && npm run data:generate && npm run data:validate && npm run data:audit-stories"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
